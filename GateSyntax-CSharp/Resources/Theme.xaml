<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="AccentColorDeep">#1D4ED8</Color>
    <Color x:Key="SurfaceColor">#F8FAFC</Color>
    <Color x:Key="SurfaceDeepColor">#1E293B</Color>
    <Color x:Key="MutedColor">#64748B</Color>
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="DangerColor">#DC2626</Color>
    <Color x:Key="SuccessColor">#16A34A</Color>

    <SolidColorBrush x:Key="Accent"      Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentDeep"  Color="{StaticResource AccentColorDeep}"/>
    <SolidColorBrush x:Key="Surface"     Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceDeep" Color="{StaticResource SurfaceDeepColor}"/>
    <SolidColorBrush x:Key="Muted"       Color="{StaticResource MutedColor}"/>
    <SolidColorBrush x:Key="Card"        Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="Danger"      Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="Success"     Color="{StaticResource SuccessColor}"/>

    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6366F1" Offset="0"/>
        <GradientStop Color="#3B82F6" Offset="0.5"/>
        <GradientStop Color="#06B6D4" Offset="1"/>
    </LinearGradientBrush>

    <sys:Double x:Key="FontSizeH1">24</sys:Double>
    <sys:Double x:Key="FontSizeH2">18</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>

    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeH1}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SurfaceDeep}"/>
        <Setter Property="Margin"     Value="0,0,0,8"/>
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeH2}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource SurfaceDeep}"/>
        <Setter Property="Margin"     Value="0,10,0,4"/>
    </Style>
    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource Muted}"/>
    </Style>

    <Style x:Key="Card.Border" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Card}"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="Padding"         Value="14"/>
        <Setter Property="Margin"          Value="6"/>
        <Setter Property="BorderBrush"     Value="#E2E8F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#1E293B" Opacity="0.06" ShadowDepth="2" BlurRadius="8"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource Accent}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="14,7"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentDeep}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
