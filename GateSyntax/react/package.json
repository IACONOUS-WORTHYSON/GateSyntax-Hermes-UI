{
  "name": "@gatesyntax/react-integrador",
  "version": "1.0.0",
  "description": "Domain-agnostic live-binding integrador for GateSyntax (React / TSX)",
  "type": "module",
  "main":   "./dist/index.js",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types":  "./dist/index.d.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc",
    "dev":   "tsc --watch"
  },
  "keywords": ["gatesyntax", "react", "live-binding", "tsx", "integrador"],
  "peerDependencies": {
    "react":     ">=18",
    "react-dom": ">=18",
    "@gatesyntax/ts": "*"
  },
  "peerDependenciesMeta": {
    "@gatesyntax/ts": { "optional": true }
  },
  "devDependencies": {
    "@types/react":     "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript":       "^5.5.3"
  }
}
