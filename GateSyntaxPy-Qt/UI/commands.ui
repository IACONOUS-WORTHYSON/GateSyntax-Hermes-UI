// commands.ui — action dispatch + async worker + gauge
/ASYNC_PROGRESS :: 0\
/ASYNC_STATUS   :: "Idle"\
/GAUGE_VAL      :: 30\
/MSG_RESULT     :: ""\

SCROLL CmdScroll :: IN [TabCommands]
COL    CmdCol    :: IN [CmdScroll]

LABEL CmdH1      :: IN [CmdCol] :: TEXT "Actions & Async"  :: STYLE "h1"
LABEL CmdCaption :: IN [CmdCol] :: TEXT "Actions dispatch from ON CLICK expressions. The async worker runs in a background QThread." :: STYLE "muted"

RULE CmdSep0 :: IN [CmdCol]

// ── Notifications ─────────────────────────────────────────────────────────────
LABEL NotifyH2 :: IN [CmdCol] :: TEXT "Notifications" :: STYLE "h2"
ROW NotifyRow :: IN [CmdCol]
BUTTON BtnInfo    :: IN [NotifyRow] :: LABEL " Info "    :: ON CLICK /DIALOG_MSG_RESULT :: "MSG_INFO"\
BUTTON BtnWarn    :: IN [NotifyRow] :: LABEL " Warn "    :: ON CLICK /DIALOG_MSG_RESULT :: "MSG_WARN"\
BUTTON BtnError   :: IN [NotifyRow] :: LABEL " Error "   :: ON CLICK /DIALOG_MSG_RESULT :: "MSG_ERROR"\
BUTTON BtnConfirm :: IN [NotifyRow] :: LABEL " Confirm " :: ON CLICK /DIALOG_MSG_RESULT :: "MSG_CONFIRM"\
LABEL MsgResult :: IN [CmdCol] :: TEXT "Last result: " + [DIALOG_MSG_RESULT]

RULE CmdSep1 :: IN [CmdCol]

// ── Async worker ──────────────────────────────────────────────────────────────
LABEL AsyncH2      :: IN [CmdCol] :: TEXT "Async Worker (QThread)" :: STYLE "h2"
LABEL AsyncStatus  :: IN [CmdCol] :: TEXT "Status: " + [ASYNC_STATUS]
BUTTON BtnAsync    :: IN [CmdCol] :: LABEL "  Start async task  " :: ON CLICK /ASYNC_STATUS :: "ASYNC_START"\
PROGRESS AsyncBar  :: IN [CmdCol] :: VALUE [ASYNC_PROGRESS] :: MAX 100
LABEL AsyncPct     :: IN [CmdCol] :: TEXT [ASYNC_PROGRESS] + " / 100"

RULE CmdSep2 :: IN [CmdCol]

// ── Gauge ─────────────────────────────────────────────────────────────────────
LABEL GaugeH2     :: IN [CmdCol] :: TEXT "Custom Gauge Widget" :: STYLE "h2"
LABEL GaugeInfo   :: IN [CmdCol] :: TEXT "Move the slider to drive the gauge."
SLIDER GaugeSlider :: IN [CmdCol] :: MIN 0 :: MAX 100 :: VALUE [GAUGE_VAL] :: ON CHANGE /GAUGE_VAL :: [GaugeSlider]\
GAUGE  DemoGauge1 :: IN [CmdCol] :: VALUE [GAUGE_VAL] :: MAX 100 :: GAUGELABEL "System Load" :: STROKE "bright_blue"
