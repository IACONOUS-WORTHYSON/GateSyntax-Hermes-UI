// main.ui — app shell with tab structure
/APP_TITLE :: "GateSyntaxPy  ·  Terminal UI Demo"\

WINDOW Root :: TITLE [APP_TITLE]
TABS MainTabs :: IN [Root]
TAB TabControls  :: IN [MainTabs] :: LABEL "Controls"
TAB TabBinding   :: IN [MainTabs] :: LABEL "Binding"
TAB TabCommands  :: IN [MainTabs] :: LABEL "Commands"
TAB TabData      :: IN [MainTabs] :: LABEL "Data"
